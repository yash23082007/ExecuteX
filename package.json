{
  "name": "executex",
  "version": "1.0.0",
  "description": "ExecuteX — 20-Language Online Compiler Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "build:client": "cd client && npm run build",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/node": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "mongoose": "^8.5.0",
    "nanoid": "^3.3.7",
    "pino": "^10.3.1",
    "react-resizable-panels": "^4.10.0",
    "vite-plugin-pwa": "^0.19.8",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  }
}
