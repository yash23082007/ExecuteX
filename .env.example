# Server
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,https://execute-x.vercel.app

# MongoDB (required for Share feature)
MONGO_URI=mongodb://localhost:27017/executex

# Upstash Redis (optional — for rate limiting & caching)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Sentry (optional — for error monitoring)
SENTRY_DSN=https://...@sentry.io/...

# Vercel (production)
ALLOWED_ORIGIN=http://localhost:5173

# AI Suggestions (optional — feature degrades gracefully without it)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash
